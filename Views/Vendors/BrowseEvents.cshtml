@model IEnumerable<INF_SP.Models.Event>

@{
    ViewData["Title"] = "Browse Events";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Browse Events</h2>
            <p class="text-muted">Find events to offer your services</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="BrowseEvents" method="get">
                <div class="row">
                    <div class="col-md-5">
                        <input type="text" name="searchString" class="form-control" placeholder="Search events..." value="@ViewBag.SearchString">
                    </div>
                    <div class="col-md-3">
                        <select name="category" class="form-select">
                            <option value="">All Categories</option>
                            <option value="Conference" selected="@(ViewBag.Category == "Conference")">Conference</option>
                            <option value="Workshop" selected="@(ViewBag.Category == "Workshop")">Workshop</option>
                            <option value="Seminar" selected="@(ViewBag.Category == "Seminar")">Seminar</option>
                            <option value="Networking" selected="@(ViewBag.Category == "Networking")">Networking</option>
                            <option value="Social" selected="@(ViewBag.Category == "Social")">Social</option>
                            <option value="Other" selected="@(ViewBag.Category == "Other")">Other</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="date" name="eventDate" class="form-control" value="@ViewBag.EventDate">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Search</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Events List -->
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var evt in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@evt.Title</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                @if (evt.Description.Length > 150)
                                {
                                    @evt.Description.Substring(0, 150)<text>...</text>
                                }
                                else
                                {
                                    @evt.Description
                                }
                            </p>

                            <div class="mb-2">
                                <small class="text-muted">
                                    <i class="bi bi-calendar"></i> @evt.EventDate.ToString("MMM dd, yyyy")
                                </small>
                                <br>
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> @evt.StartTime.ToString(@"hh\:mm") - @evt.EndTime.ToString(@"hh\:mm")
                                </small>
                                <br>
                                <small class="text-muted">
                                    <i class="bi bi-geo-alt"></i> @evt.Location
                                </small>
                                <br>
                                <small class="text-muted">
                                    <i class="bi bi-person"></i> Organizer: @evt.Organizer?.Name
                                </small>
                            </div>

                            <span class="badge bg-secondary">@evt.Category</span>
                        </div>
                        <div class="card-footer">
                            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#messageModal-@evt.Id">
                                <i class="bi bi-envelope"></i> Contact Organizer
                            </button>
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@evt.Id" class="btn btn-outline-primary btn-sm">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Message Modal for each event -->
                <div class="modal fade" id="messageModal-@evt.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Message @evt.Organizer?.Name</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form asp-controller="Messages" asp-action="Send" method="post">
                                <div class="modal-body">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="recipientId" value="@evt.OrganizerId" />
                                    <input type="hidden" name="eventId" value="@evt.Id" />
                                    
                                    <div class="mb-3">
                                        <label class="form-label"><strong>Event:</strong></label>
                                        <p>@evt.Title</p>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="messageText-@evt.Id" class="form-label">Your Message</label>
                                        <textarea name="messageText" id="messageText-@evt.Id" class="form-control" rows="5" placeholder="Introduce your services and how you can help with this event..." required></textarea>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-send"></i> Send Message
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <h4>No Events Found</h4>
            <p>There are no upcoming events at this time.</p>
            @if (!string.IsNullOrEmpty(ViewBag.SearchString as string))
            {
                <a asp-action="BrowseEvents" class="btn btn-primary">Clear Search</a>
            }
        </div>
    }
</div>
